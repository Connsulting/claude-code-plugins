{
  "policy": {
    "defaultPath": "PRIVACY_POLICY.md"
  },
  "source": {
    "include": [
      "*.py",
      "**/*.py",
      "*.js",
      "**/*.js",
      "*.ts",
      "**/*.ts",
      "*.tsx",
      "**/*.tsx",
      "*.jsx",
      "**/*.jsx",
      "*.go",
      "**/*.go",
      "*.java",
      "**/*.java",
      "*.rb",
      "**/*.rb",
      "*.php",
      "**/*.php",
      "*.cs",
      "**/*.cs",
      "*.swift",
      "**/*.swift",
      "*.kt",
      "**/*.kt",
      "*.rs",
      "**/*.rs",
      "*.sh",
      "**/*.sh",
      "*.yaml",
      "**/*.yaml",
      "*.yml",
      "**/*.yml",
      "*.json",
      "**/*.json",
      "*.toml",
      "**/*.toml"
    ],
    "exclude": [
      ".git/**",
      "**/.git/**",
      ".claude/**",
      "**/.claude/**",
      ".claude-plugin/**",
      "**/.claude-plugin/**",
      "tests/**",
      "**/tests/**",
      "test/**",
      "**/test/**",
      "vendor/**",
      "**/vendor/**",
      "node_modules/**",
      "**/node_modules/**",
      "dist/**",
      "**/dist/**",
      "build/**",
      "**/build/**",
      ".next/**",
      "**/.next/**",
      "coverage/**",
      "**/coverage/**",
      "__pycache__/**",
      "**/__pycache__/**",
      ".venv/**",
      "**/.venv/**",
      "venv/**",
      "**/venv/**",
      "*.min.js",
      "**/*.min.js",
      "*.map",
      "**/*.map"
    ]
  },
  "network": {
    "allowlistDomains": []
  },
  "scanner": {
    "maxFileSizeBytes": 1000000
  }
}
