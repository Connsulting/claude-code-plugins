{
  "sqlite": {
    "dbPath": "${HOME}/.claude/compound-learning.db"
  },
  "learnings": {
    "globalDir": "${HOME}/.projects/learnings",
    "repoSearchPath": "${HOME}",
    "archiveDir": "${HOME}/.projects/archive/learnings",
    "highConfidenceThreshold": 0.4,
    "possiblyRelevantThreshold": 0.55,
    "keywordBoostWeight": 0.65
  },
  "consolidation": {
    "duplicateThreshold": 0.25,
    "scopeKeywords": [
      "security",
      "authentication",
      "jwt",
      "oauth",
      "encryption",
      "password",
      "token",
      "api-key",
      "secret",
      "xss",
      "sql-injection"
    ],
    "outdatedKeywords": [
      "temporary",
      "workaround",
      "deprecated",
      "todo",
      "fixme",
      "hack",
      "remove later",
      "obsolete"
    ]
  }
}
